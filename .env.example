# ========== Railway：运行 server.js 时在 Railway Variables 里配置 ==========
PORT=
HOST=0.0.0.0
TURN_USER=
TURN_PASS=
METERED_DOMAIN=hongda.metered.live
METERED_SECRET=

# ========== Vercel（或本地 Next）：浏览器可读，必须以 NEXT_PUBLIC_ 开头 ==========
# Railway 公网域名，把 https:// 换成 wss://，不要末尾斜杠，不要带 ?r=
# 例: wss://jikechat-chat.up.railway.app
NEXT_PUBLIC_WS_URL=wss://jikechat-chat.up.railway.app
